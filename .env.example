# Copy → .env (local hoặc VPS production)
# cp .env.example .env
# Giải thích đầy đủ từng biến: docs/VPS-SETUP.md (Bước 5)

# =============================================================================
# DATABASE (PostgreSQL + pgvector)
# =============================================================================
POSTGRES_USER=tosuthien
POSTGRES_PASSWORD=thamthien
POSTGRES_DB=tosuthien
POSTGRES_PORT=5432

# Host scripts (ingest.py, embed.py) — localhost
DATABASE_URL=postgresql://tosuthien:thamthien@localhost:5432/tosuthien
# Container api tự dùng host "db" — không cần sửa DATABASE_URL cho Docker

# =============================================================================
# DOCKER COMPOSE
# =============================================================================
API_PORT=8000
ADMIN_PORT=5173

# =============================================================================
# API NESTJS
# =============================================================================
PORT=8000
PUBLIC_BASE_URL=https://api.tosuthien.net
DATA_ROOT=../data

# =============================================================================
# CHAT RAG — CHAT_PROVIDER=flare | hhtech | nexus | shopaikey
# Optional: CHAT_FALLBACK_PROVIDER=nexus (used when primary fails)
# =============================================================================
CHAT_PROVIDER=flare
CHAT_MODEL=pro/claude-opus-4-8
CHAT_FALLBACK_PROVIDER=nexus

FLARE_API_KEY=
FLARE_BASE_URL=https://9flare.com/api/v1
FLARE_CHAT_MODEL=pro/claude-opus-4-8

HHTECH_API_KEY=
HHTECH_BASE_URL=https://hhtechapi.com/v1
HHTECH_CHAT_MODEL=claude-opus-4-6

NEXUS_BASE_URL=https://nexusmmo.store/api/v1
NEXUS_API_KEY=
NEXUS_CHAT_MODEL=claude-opus-4-8

SHOPAIKEY_API_KEY=
SHOPAIKEY_BASE_URL=https://api.shopaikey.com

# =============================================================================
# EMBEDDING — local (scripts/embed_server.py), không tốn phí API
# =============================================================================
EMBEDDING_API_KEY=local
EMBEDDING_BASE_URL=http://localhost:7997/v1
EMBEDDING_BASE_URL_DOCKER=http://host.docker.internal:7997/v1
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
EMBED_PORT=7997

# =============================================================================
# OCR PDF — pdf_to_text.py (OCR_PROVIDER=hhtech | taphoa | nexus | shopaikey)
# =============================================================================
OCR_PROVIDER=hhtech
OCR_MODEL=claude-opus-4-6

TAPHOA_API_KEY=
TAPHOA_BASE_URL=https://taphoaapi.info.vn

# =============================================================================
# NGINX host (tham chiếu)
# =============================================================================
HTTP_PORT=80
HTTPS_PORT=443
