# Copy → .env (local) hoặc .env.production (VPS)
# cp .env.example .env

# Database: tosuthien (PostgreSQL + pgvector)
POSTGRES_USER=tosuthien
POSTGRES_PASSWORD=thamthien
POSTGRES_DB=tosuthien
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql://tosuthien:thamthien@localhost:5432/tosuthien
# Trong docker network dùng host "db":
# DATABASE_URL=postgresql://tosuthien:thamthien@db:5432/tosuthien

SHOPAIKEY_API_KEY=
SHOPAIKEY_BASE_URL=https://api.shopaikey.com

# Embedding — ShopAIKey KHÔNG có embedding.
# Mặc định: server local miễn phí (scripts/embed_server.py, model multilingual-e5-large).
#   python3 scripts/embed_server.py   → chạy trước khi embed / chat vector
# Hoặc dùng OpenAI: EMBEDDING_BASE_URL=https://api.openai.com/v1, MODEL=text-embedding-3-small
EMBEDDING_API_KEY=local
EMBEDDING_BASE_URL=http://localhost:7997/v1
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# Chat RAG — CHAT_PROVIDER=shopaikey | nexus
CHAT_PROVIDER=shopaikey
CHAT_MODEL=claude-opus-4-8

# Option 2 — Nexus (Anthropic-compatible proxy)
NEXUS_BASE_URL=https://nexusmmo.store/api/v1
NEXUS_API_KEY=
NEXUS_CHAT_MODEL=claude-opus-4-8
# topK mặc định server = 5, lookup = 3, so sánh = 8, max = 10 — xem rag.constants.ts

# Nginx
HTTP_PORT=80
HTTPS_PORT=443

# Public URL (API serve files + DB public_url)
PUBLIC_BASE_URL=http://localhost:8000
PORT=8000
DATA_ROOT=../data
